{
  "expo": {
    "name": "gooflo.",
    "slug": "gooflo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gooflo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#BFFF00"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gooflo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Gooflo, AI ile dönüştürmek istediğin selfie'yi çekmek için kameraya erişim gerektirir.",
        "NSPhotoLibraryUsageDescription": "Gooflo, AI ile dönüştürmek istediğin fotoğrafı seçmek için fotoğraf kütüphanesine erişim gerektirir.",
        "NSUserTrackingUsageDescription": "Sana özel deneyim sunmak için kullanım verilerini takip etmek istiyoruz.",
        "NSMicrophoneUsageDescription": "Bazı özellikler için mikrofon erişimi gerekebilir.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      }
    },
    "android": {
      "package": "com.gooflo.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#BFFF00"
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#BFFF00"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Sana özel deneyim sunmak için kullanım verilerini takip etmek istiyoruz."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#BFFF00"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Gooflo, AI ile dönüştürmek istediğin selfie'yi çekmek için kameraya erişim gerektirir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Gooflo, AI ile dönüştürmek istediğin fotoğrafı seçmek için fotoğraf kütüphanesine erişim gerektirir."
        }
      ],
      "@sentry/react-native/expo",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}

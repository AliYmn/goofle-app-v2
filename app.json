{
  "expo": {
    "name": "gooflo.",
    "slug": "gooflo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gooflo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A1A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.gooflo.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Gooflo, AI ile dönüştürmek istediğin selfie'yi çekmek için kameraya erişim gerektirir.",
        "NSPhotoLibraryUsageDescription": "Gooflo, AI ile dönüştürmek istediğin fotoğrafı seçmek için fotoğraf kütüphanesine erişim gerektirir.",
        "NSUserTrackingUsageDescription": "Sana özel deneyim sunmak için kullanım verilerini takip etmek istiyoruz.",
        "NSMicrophoneUsageDescription": "Bazı özellikler için mikrofon erişimi gerekebilir.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:gooflo.yamapps.com"
      ],
      "entitlements": {
        "com.apple.developer.applesignin": [
          "Default"
        ]
      }
    },
    "android": {
      "package": "com.gooflo.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#BFFF00"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "com.google.android.gms.permission.AD_ID",
        "android.permission.RECORD_AUDIO"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "gooflo.yamapps.com",
              "pathPrefix": "/mod/"
            },
            {
              "scheme": "https",
              "host": "gooflo.yamapps.com",
              "pathPrefix": "/g/"
            },
            {
              "scheme": "https",
              "host": "gooflo.yamapps.com",
              "pathPrefix": "/collection/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#1A1A1A"
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Sana özel deneyim sunmak için kullanım verilerini takip etmek istiyoruz."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#BFFF00"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Gooflo, AI ile dönüştürmek istediğin selfie'yi çekmek için kameraya erişim gerektirir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Gooflo, AI ile dönüştürmek istediğin fotoğrafı seçmek için fotoğraf kütüphanesine erişim gerektirir."
        }
      ],
      "@sentry/react-native/expo",
      "@react-native-google-signin/google-signin",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "da69fbb0-5f3c-44a2-9c6e-a72536ce0a49"
      },
      "router": {
        "origin": "https://gooflo.yamapps.com"
      }
    },
    "owner": "aliymn44"
  }
}

# ==========================================
# Gooflo Mobile App - Environment Variables
# ==========================================
# NOTE: If you are using Expo, variables that need to be accessed
# on the client side must be prefixed with EXPO_PUBLIC_.

# ------------------------------------------
# Supabase (Database, Auth, Storage)
# ------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=""
EXPO_PUBLIC_SUPABASE_ANON_KEY=""
# Only use SERVICE_ROLE_KEY in secure backend environments!
SUPABASE_SERVICE_ROLE_KEY=""

# ------------------------------------------
# Fal AI (Generative AI)
# ------------------------------------------
# Fal AI key for generative AI models (used from Edge Functions)
FAL_API_KEY=""

# ------------------------------------------
# Resend (Email Services)
# ------------------------------------------
# Resend API key for sending emails (used from Edge Functions)
RESEND_API_KEY=""

# ------------------------------------------
# RevenueCat (In-App Purchases)
# ------------------------------------------
# Single public API key for React Native (works for both iOS & Android)
EXPO_PUBLIC_REVENUECAT_API_KEY=""
# Webhook secret for server-side validation (used by Edge Functions)
REVENUECAT_WEBHOOK_SECRET=""

# ------------------------------------------
# PostHog (Analytics)
# ------------------------------------------
EXPO_PUBLIC_POSTHOG_API_KEY=""
EXPO_PUBLIC_POSTHOG_HOST=""

# ------------------------------------------
# Sentry (Error Tracking)
# ------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=""
# Required for uploading sourcemaps during the build process
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ------------------------------------------
# Expo (Push Notifications)
# ------------------------------------------
# Found in your Expo dashboard → Project Settings
EXPO_PUBLIC_EAS_PROJECT_ID=""
